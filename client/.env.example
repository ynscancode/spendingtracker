# Backend API origin used by the production build. Leave empty for local dev
# (requests stay relative and go through vite.config.js's dev-server proxy to
# http://localhost:4000). Set to the deployed Fly.io backend's absolute origin
# (no trailing slash) when building for production, e.g.:
#   VITE_API_URL=https://your-app.fly.dev
# This file is a template — copy to client/.env (gitignored) and fill in the
# real value, or set VITE_API_URL directly in your hosting provider's build
# environment variables (Vercel/Netlify project settings).
VITE_API_URL=
