# Turso (libSQL) database connection — REQUIRED, no local-file fallback.
# The server will not start without both of these set.
# For LOCAL dev with no cloud DB, use a file: URL instead of a real Turso database —
# TURSO_DATABASE_URL=file:./budget.db works with no auth token required (file: URLs
# don't need one); this is how QA smoke-tested the no-cloud path.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Simple static-token infra gate ("can you talk to this API at all"). Set to any
# long random string in production to protect the API. Leave unset for local dev
# (gate is skipped when not set). Sent by clients as the `X-API-Token` header
# (BATCH 11: moved off `Authorization`, which is now reserved for the per-user
# JWT below) or, for the transactions export anchor-nav download only, as a
# `?token=` query param. Generate one with: openssl rand -hex 32
API_TOKEN=

# Comma-separated list of allowed CORS origins for the public deployment (e.g.
# https://your-app.vercel.app). Leave unset for local dev (falls back to fully
# open CORS, fine when the API isn't publicly exposed).
CORS_ORIGIN=

# REQUIRED. Secret used to sign/verify per-user JWTs (BATCH 11 user auth). The
# server FAILS LOUD AT BOOT if this is unset or blank — there is no fallback.
# Tokens do not expire; rotating this secret is the only revocation lever (it
# invalidates every existing session at once). Generate a strong value with:
# openssl rand -base64 32
JWT_SECRET=

# Ollama Cloud config for the optional "Suggest with AI" import feature.
# The feature is hard-disabled (no external call) unless OLLAMA_CLOUD_API_KEY is set.
# This file is a template — copy to server/.env (gitignored) and fill in a real key.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=gpt-oss:20b-cloud
OLLAMA_CLOUD_BASE_URL=https://ollama.com
